# OpenClaw Skylight environment (copy to .env and fill in)

# Skylight frame
SKYLIGHT_EMAIL=
SKYLIGHT_PASSWORD=
SKYLIGHT_FRAME_ID=
SKYLIGHT_URL=https://app.ourskylight.com
SKYLIGHT_TIMEZONE=America/Los_Angeles
SKYLIGHT_DEFAULT_GROCERY_LIST_ID=
SKYLIGHT_FAMILY_TALK_ROOM=
SKYLIGHT_OPS_TALK_ROOM=

# Nextcloud (Talk + Mail)
NEXTCLOUD_URL=https://nextcloud.example.com
NEXTCLOUD_USER=
NEXTCLOUD_PASS=

# Email enrich (optional)
FAMILY_GMAIL_ADDRESS=
FAMILY_MAIL_ACCOUNT_ID=
FAMILY_GMAIL_SECRET_FILE=~/.openclaw/.env.d/family-gmail-mail.secret

# OpenClaw agent mention (Talk proposal replies)
OPENCLAW_AGENT_MENTION=@openclaw

# Week-2 capacity / health (optional)
OPENCLAW_GATEWAY_HEALTH_URL=http://127.0.0.1:18789/health
MAVLINK_GATEWAY_HEALTH_URL=
EMAIL_TO_EVENT_AUTO=0
NEXTCLOUD_DB_BACKUP_DIR=
NEXTCLOUD_BACKUP_LOG=
# Post all Talk replies as NEXTCLOUD_USER (same as talk-post.sh), not Talk Bot API
NEXTCLOUD_TALK_USER_OUTBOUND=1
# OPENCLAW_CRON_UNIT_PREFIX=openclaw-cron
# PERF4_MAX_WAIT_S=600

# Repo root when using install script
OPENCLAW_SKYLIGHT_ROOT=

# Ops + work mail (digest / urgent scan; family stays read-only enrich)
OPS_GMAIL_ADDRESS=
OPS_MAIL_ACCOUNT_ID=
OPS_GMAIL_SECRET_FILE=~/.openclaw/.env.d/ops-gmail-mail.secret
WORK_GMAIL_ADDRESS=
WORK_MAIL_ACCOUNT_ID=
WORK_GMAIL_SECRET_FILE=~/.openclaw/.env.d/work-gmail-mail.secret
EMAIL_DIGEST_OPS_ROOM=
EMAIL_DIGEST_WORK_ROOM=
URGENT_SCAN_ACCOUNTS=ops,work
MAIL_ACCOUNTS_JSON=~/.openclaw/config/mail-accounts.json

# 3DPrintForge + K1 Max (Alfred integration)
FORGE_ENABLED=1
FORGE_API_URL=https://127.0.0.1:3040
FORGE_API_KEY_FILE=~/.openclaw/.env.d/forge-api.secret
FORGE_PRINTER_ID=k1-max
FORGE_DASHBOARD_URL=https://forge-vdroners.ddns.net
FORGE_ALERT_TALK_ROOM=
FORGE_WEBHOOK_SECRET_FILE=~/.openclaw/.env.d/forge-webhook.secret
FORGE_WEBHOOK_BIND=0.0.0.0
FORGE_WEBHOOK_PORT=8790
FORGE_PUBLIC_WEBHOOK_URL=https://alfred-vdroners.ddns.net/forge-webhook
# CPM upstream: docker relay hostname when using setup-forge-webhook-relay-docker.sh
FORGE_CPM_UPSTREAM_HOST=forge-webhook-relay
FORGE_QUIET_HOURS=23:00-07:00
FORGE_QUIET_CRITICAL_OVERRIDE=1
FORGE_ALERT_MIN_INTERVAL_M=15
FORGE_STUCK_PRINT_H=2
FORGE_SLICER_DOWN_M=10
FORGE_NATIVE_NOTIFY=0

# Nextcloud DB backup (alfred-nc-db-backup.timer at 03:05)
NEXTCLOUD_DB_BACKUP_DIR=/media/4TB/backups/nextcloud-db
NEXTCLOUD_BACKUP_RUN_LOG=/media/4TB/backups/nextcloud-backup.log
NEXTCLOUD_BACKUP_LOG=/media/4TB/ops/reports/backup-enhanced.log
# MYSQL_PASSWORD=   # optional; defaults to cloud_db container env
