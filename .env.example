# OpenClaw Skylight environment (copy to .env and fill in)

# Skylight frame
SKYLIGHT_EMAIL=
SKYLIGHT_PASSWORD=
SKYLIGHT_FRAME_ID=
SKYLIGHT_URL=https://app.ourskylight.com
SKYLIGHT_TIMEZONE=America/Los_Angeles
SKYLIGHT_DEFAULT_GROCERY_LIST_ID=
SKYLIGHT_FAMILY_TALK_ROOM=
SKYLIGHT_OPS_TALK_ROOM=

# Nextcloud (Talk + Mail)
NEXTCLOUD_URL=https://nextcloud.example.com
NEXTCLOUD_USER=
NEXTCLOUD_PASS=

# Email enrich (optional)
FAMILY_GMAIL_ADDRESS=
FAMILY_MAIL_ACCOUNT_ID=
FAMILY_GMAIL_SECRET_FILE=~/.openclaw/.env.d/family-gmail-mail.secret

# OpenClaw agent mention (Talk proposal replies)
OPENCLAW_AGENT_MENTION=@openclaw

# Week-2 capacity / health (optional)
OPENCLAW_GATEWAY_HEALTH_URL=http://127.0.0.1:18789/health
MAVLINK_GATEWAY_HEALTH_URL=
EMAIL_TO_EVENT_AUTO=0
NEXTCLOUD_DB_BACKUP_DIR=
NEXTCLOUD_BACKUP_LOG=
# OPENCLAW_CRON_UNIT_PREFIX=openclaw-cron
# PERF4_MAX_WAIT_S=600

# Repo root when using install script
OPENCLAW_SKYLIGHT_ROOT=

# Ops + work mail (digest / urgent scan; family stays read-only enrich)
OPS_GMAIL_ADDRESS=
OPS_MAIL_ACCOUNT_ID=
OPS_GMAIL_SECRET_FILE=~/.openclaw/.env.d/ops-gmail-mail.secret
WORK_GMAIL_ADDRESS=
WORK_MAIL_ACCOUNT_ID=
WORK_GMAIL_SECRET_FILE=~/.openclaw/.env.d/work-gmail-mail.secret
EMAIL_DIGEST_OPS_ROOM=
EMAIL_DIGEST_WORK_ROOM=
URGENT_SCAN_ACCOUNTS=ops,work
MAIL_ACCOUNTS_JSON=~/.openclaw/config/mail-accounts.json
